{
    "version": 2,
    "functions": {
        "api/*.ts": {
            "runtime": "@vercel/node"
        }
    },
    "rewrites": [
        {
            "source": "/api/whatsapp/webhook",
            "destination": "/api/webhook"
        },
        {
            "source": "/api/(.*)",
            "destination": "/api/index"
        },
        {
            "source": "/((?!api/|assets/|favicon|logo|manifest|.*\\..*).*)",
            "destination": "/index.html"
        }
    ]
}
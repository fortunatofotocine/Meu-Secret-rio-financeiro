{
    "version": 2,
    "rewrites": [
        {
            "source": "/api/whatsapp/webhook",
            "destination": "/api/index"
        },
        {
            "source": "/api/:path*",
            "destination": "/api/index"
        },
        {
            "source": "/((?!api/|assets/|favicon|zlai-logo|manifest|.*\\..*).*)",
            "destination": "/index.html"
        }
    ]
}
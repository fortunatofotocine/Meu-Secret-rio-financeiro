{
    "version": 2,
    "rewrites": [
        {
            "source": "/api/whatsapp/webhook",
            "destination": "/api/webhook"
        },
        {
            "source": "/api/health",
            "destination": "/api/health"
        },
        {
            "source": "/api/(.*)",
            "destination": "/api/index"
        },
        {
            "source": "/((?!api/|assets/|favicon|.*\\.).*)",
            "destination": "/index.html"
        }
    ]
}
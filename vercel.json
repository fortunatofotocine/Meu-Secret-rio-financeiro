{
    "version": 2,
    "functions": {
        "api/server.ts": {
            "runtime": "@vercel/node"
        }
    },
    "routes": [
        {
            "src": "/api/(.*)",
            "dest": "/api/server"
        },
        {
            "handle": "filesystem"
        },
        {
            "src": "/assets/(.*)",
            "dest": "/assets/$1"
        },
        {
            "src": "/((?!api/).*)",
            "dest": "/index.html"
        }
    ]
}
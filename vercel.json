{
    "version": 2,
    "rewrites": [
        {
            "source": "/api/whatsapp/webhook",
            "destination": "/api/webhook"
        },
        {
            "source": "/api/:path*",
            "destination": "/api/index"
        },
        {
            "source": "/((?!api/|.*\\.).*)",
            "destination": "/index.html"
        }
    ]
}
{
    "version": 2,
    "rewrites": [
        {
            "source": "/api/whatsapp/webhook",
            "destination": "/api/webhook"
        },
        {
            "source": "/api/(.*)",
            "destination": "/api/index"
        },
        {
            "source": "/((?!api/|.*\\.(?:js|css|png|jpg|jpeg|gif|ico|webmanifest|svg|woff|woff2|ttf|otf|mp4)).*)",
            "destination": "/index.html"
        }
    ]
}
{
    "version": 2,
    "builds": [
        {
            "src": "server.ts",
            "use": "@vercel/node"
        },
        {
            "src": "api/webhook.ts",
            "use": "@vercel/node"
        },
        {
            "src": "package.json",
            "use": "@vercel/static-build",
            "config": {
                "distDir": "dist"
            }
        }
    ],
    "rewrites": [
        {
            "source": "/api/whatsapp/webhook",
            "destination": "api/webhook.ts"
        },
        {
            "source": "/api/(.*)",
            "destination": "server.ts"
        },
        {
            "source": "/((?!api/|assets/|.*\\.).*)",
            "destination": "/index.html"
        }
    ]
}
{
    "version": 2,
    "builds": [
        {
            "src": "server.ts",
            "use": "@vercel/node"
        },
        {
            "src": "api/webhook.ts",
            "use": "@vercel/node"
        },
        {
            "src": "package.json",
            "use": "@vercel/static-build",
            "config": {
                "distDir": "dist"
            }
        }
    ],
    "routes": [
        {
            "src": "/api/whatsapp/webhook",
            "dest": "api/webhook.ts"
        },
        {
            "src": "/api/(.*)",
            "dest": "server.ts"
        },
        {
            "src": "/assets/(.*)",
            "dest": "/assets/$1"
        },
        {
            "src": "/favicon.ico",
            "dest": "/favicon.ico"
        },
        {
            "src": "/zlai-logo.png",
            "dest": "/zlai-logo.png"
        },
        {
            "src": "/manifest.webmanifest",
            "dest": "/manifest.webmanifest"
        },
        {
            "src": "/(.*\\..*)",
            "dest": "/$1"
        },
        {
            "src": "/(.*)",
            "dest": "/index.html"
        }
    ]
}